        {
          "name": "update-booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 - Booking updated successfully\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Check if basic info was updated correctly\", function () {\r",
                  "    pm.expect(jsonData.firstname).to.eql(\"Agata\");\r",
                  "    pm.expect(jsonData.lastname).to.eql(\"Binkowska\");\r",
                  "    pm.expect(jsonData.totalprice).to.eql(666);\r",
                  "    pm.expect(jsonData.depositpaid).to.eql(true);\r",
                  "    pm.expect(jsonData.additionalneeds).to.eql(\"Breakfast\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check if booking dates were updated correctly\", function () {\r",
                  "    pm.expect(jsonData.bookingdates.checkin).to.eql(\"2026-05-11\");\r",
                  "    pm.expect(jsonData.bookingdates.checkout).to.eql(\"2026-05-17\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
